# Production environment variables
# Copy to .env.production and fill in values

# ─── API Server ───────────────────────────────────────────────────────────────
# Backend FastAPI URL (LAN IP when accessed from same network)
VITE_API_BASE_URL=http://192.168.31.233:8080/

# ─── Dashboard Policy ─────────────────────────────────────────────────────────
# Dashboard (Streamlit :8501) is LAN-ONLY — not forwarded to internet.
# Access: same WiFi → http://192.168.31.233:8501
# External: VPN or direct remote access only

# ─── Environment Mode ─────────────────────────────────────────────────────────
HERMES_ENV=production