# hermes-web-ui — environment config
# Copy to .env.local and fill in values

# API server URL (must have trailing slash removed)
# For local dev: http://localhost:8080/
# For production: http://<your-server-ip>:8080/
VITE_API_BASE_URL=http://localhost:8080/

# API server URL for production (external access via LAN)
# Replace with your server's LAN IP when accessing from other devices
VITE_API_BASE_URL_PROD=http://192.168.31.233:8080/