# HERMES Web UI · sample env
# Copy to `.env.local` and edit. All keys MUST start with VITE_.
# Empty / missing keys → v1 mock mode (default).

# Base URL of the FastAPI backend (omit the /api suffix). When set, every
# fetch in src/api/client.ts routes through this instead of returning mocks.
# Example: VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=

# Optional SSE endpoint override. By default it's derived from
# ${VITE_API_BASE_URL}/events. Set only if your backend mounts SSE elsewhere.
# Example: VITE_SSE_URL=http://localhost:8000/api/sse
VITE_SSE_URL=

# Telegram Mini-App mode. Set to "1" (any truthy string) to enable the
# initData → JWT auth flow. v1 client.ts ignores this — see docs/MINI_APP.md.
# Example: VITE_MINI_APP=1
VITE_MINI_APP=
